generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // URLs are now managed by prisma.config.ts
}

model User {
  id        String   @id // This will match the Clerk User ID (e.g., 'user_2...')
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  orders    Order[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  brand         String   // e.g., "Tom Ford", "Creed"
  price         Float
  sizeMl        Int      // e.g., 50, 100
  concentration String   // e.g., "Eau de Parfum", "Extrait de Parfum"
  gender        String   // "Men", "Women", "Unisex"
  imageUrls     String[] // Array of image links
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems    OrderItem[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
  total     Float
  status    String      @default("PENDING") // PENDING, PAID, SHIPPED
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}