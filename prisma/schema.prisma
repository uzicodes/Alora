generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id // This will match the Clerk User ID (e.g., 'user_2...')
  email         String   @unique
  firstName     String?
  lastName      String?
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  orders        Order[]
}

model Product {
  id           String   @id @default(cuid())
  name         String
  brand        String   @default("ALORA")
  description  String
  price        Float
  images       String[] // Array of image URLs for the luxury gallery
  category     String   // e.g., "Eau de Parfum", "Extrait de Parfum"
  
  // Perfume-specific attributes
  topNotes     String[] // Initial scent
  middleNotes  String[] // Heart notes
  baseNotes    String[] // Lasting scent
  longevity    String?  // e.g., "Long-lasting (8h+)"
  gender       String   @default("Unisex") // Unisex, Men, Women
  
  stock        Int      @default(0)
  isFeatured   Boolean  @default(false)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  orderItems   OrderItem[]
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  items     OrderItem[]
  total     Float
  status    String      @default("PENDING") // PENDING, PAID, SHIPPED
  createdAt DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
}