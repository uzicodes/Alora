generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Product {
  id            String   @id @default(cuid())
  name          String
  brand         String   
  price         Float
  sizeMl        Int      
  concentration String   
  gender        String   
  imageUrls     String[] 
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id        String   @id    // Clerk User ID 
  email     String   @unique
  name      String?   
  phone     String?   
  address   String?  

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

                          // link orders to this user
  orders    Order[]  
}

model Order {
  id          String   @id @default(cuid())        // Unique Order ID
  userId      String                               
  name        String   
  email       String   
  orderTime   DateTime @default(now())
  
                                          // entire cart (items, quantities, prices) JSON 
  items       Json     
  
  totalCost   Float
  paymentType String   

                                         // links Order back to the User table
  user        User     @relation(fields: [userId], references: [id])

  @@map("Orders")
}